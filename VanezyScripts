local leftPad, rightPad
local function buildMobilePads()
    local function pad(anchorX, posX)
        local p = Instance.new("Frame")
        p.AnchorPoint = Vector2.new(anchorX, 0.5)
        p.Position = UDim2.new(posX, anchorX == 0 and 24 or -24, 0.5, 40)
        p.Size = UDim2.new(0, 0, 0, 0)
