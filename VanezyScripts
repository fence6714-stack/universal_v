local function createHelpButton(parent, text)
    local helpBtn = Instance.new("TextButton")
    helpBtn.Size = UDim2.new(0, 16, 0, 16)
    helpBtn.Position = UDim2.new(0, 0, 0.5, -8)
    helpBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    helpBtn.BackgroundTransparency = 0.5
    helpBtn.BorderSizePixel = 0
    helpBtn.Text = "?"
    helpBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    helpBtn.Font = Enum.Font.GothamBold
    helpBtn.TextSize = 10
    helpBtn.ZIndex = 20
    helpBtn.Parent = parent
    Instance.new("UICorner", helpBtn).CornerRadius = UDim.new(1, 0)
    
    local tooltip = Instance.new("Frame")
    tooltip.Size = UDim2.new(0, 200, 0, 50)
    tooltip.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    tooltip.BackgroundTransparency = 0.2
    tooltip.BorderSizePixel = 0
    tooltip.ClipsDescendants = true
    tooltip.Visible = false
    tooltip.ZIndex = 100
    tooltip.Parent = MainGui
    
    local gradient = Instance.new("UIGradient", tooltip)
    local hue = 0
    task.spawn(function()
        while true do
            if not tooltip.Visible or not tooltip.Parent then task.wait(0.5) continue end
            hue = (hue + 0.005) % 1
            pcall(function() gradient.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromHSV(hue, 0.5, 1)), ColorSequenceKeypoint.new(0.5, Color3.fromHSV((hue+0.3)%1, 0.5, 1)), ColorSequenceKeypoint.new(1, Color3.fromHSV((hue+0.6)%1, 0.5, 1))}) end)
            task.wait(0.03)
        end
    end)
    
    Instance.new("UICorner", tooltip).CornerRadius = UDim.new(0, 8)
    Instance.new("UIStroke", tooltip).Color = Color3.fromRGB(80, 80, 80)
    
    local tooltipText = Instance.new("TextLabel")
    tooltipText.Size = UDim2.new(1, -12, 1, -6)
    tooltipText.Position = UDim2.new(0, 6, 0, 3)
    tooltipText.BackgroundTransparency = 1
    tooltipText.Text = text
    tooltipText.TextColor3 = Color3.fromRGB(220, 220, 220)
    tooltipText.Font = Enum.Font.Gotham
    tooltipText.TextSize = 10
    tooltipText.TextWrapped = true
    tooltipText.TextXAlignment = Enum.TextXAlignment.Left
    tooltipText.ZIndex = 101
    tooltipText.Parent = tooltip
    
    local tooltipData = {tooltip = tooltip, helpBtn = helpBtn, tooltipOpen = false}
    
    local function updatePosition()
        local pos = helpBtn.AbsolutePosition
        local size = helpBtn.AbsoluteSize
        tooltip.Position = UDim2.new(0, pos.X + size.X + 5, 0, pos.Y - 10)
    end
    
    helpBtn.MouseButton1Click:Connect(function()
        closeAllTooltips()
        tooltipData.tooltipOpen = not tooltipData.tooltipOpen
        if tooltipData.tooltipOpen then
            updatePosition()
            tooltip.Visible = true
            helpBtn.BackgroundColor3 = Color3.fromRGB(255, 120, 80)
            tooltip.Size = UDim2.new(0, 0, 0, 50)
            TweenService:Create(tooltip, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(0, 200, 0, 50)}):Play()
            table.insert(allTooltips, tooltipData)
        else
            helpBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            TweenService:Create(tooltip, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 50)}):Play()
            task.delay(0.2, function() tooltip.Visible = false end)
        end
    end)
    return helpBtn
end

