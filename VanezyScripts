local function updateActiveFunctions()
    activeFunctions = {}
    if getgenv().ESPPlayers then table.insert(activeFunctions, {name = "ESP", toggle = StatusToggleBg}) end
    if getgenv().Aimbot then table.insert(activeFunctions, {name = "Aimbot", toggle = StatusToggleBg}) end
    if getgenv().Tracers then table.insert(activeFunctions, {name = "Tracers", toggle = StatusToggleBg}) end
    if getgenv().AntiAFK then table.insert(activeFunctions, {name = "Anti AFK", toggle = StatusToggleBg}) end
    
    if #activeFunctions == 0 then
        StatusText.Text = ""
        StatusLeftArrow.TextColor3 = Color3.fromRGB(60, 60, 60)
        StatusRightArrow.TextColor3 = Color3.fromRGB(60, 60, 60)
    elseif #activeFunctions == 1 then
        currentStatusIndex = 1
        StatusText.Text = activeFunctions[1].name
        StatusLeftArrow.TextColor3 = Color3.fromRGB(60, 60, 60)
        StatusRightArrow.TextColor3 = Color3.fromRGB(60, 60, 60)
    else
        if currentStatusIndex > #activeFunctions then currentStatusIndex = #activeFunctions end
        StatusText.Text = activeFunctions[currentStatusIndex].name
        StatusLeftArrow.TextColor3 = currentStatusIndex > 1 and Color3.fromRGB(200, 200, 200) or Color3.fromRGB(60, 60, 60)
        StatusRightArrow.TextColor3 = currentStatusIndex < #activeFunctions and Color3.fromRGB(200, 200, 200) or Color3.fromRGB(60, 60, 60)
    end
end

StatusLeftArrow.MouseButton1Click:Connect(function()
    if #activeFunctions > 1 and currentStatusIndex > 1 then
        currentStatusIndex = currentStatusIndex - 1
        StatusText.Text = activeFunctions[currentStatusIndex].name
        updateActiveFunctions()
    end
end)

StatusRightArrow.MouseButton1Click:Connect(function()
    if #activeFunctions > 1 and currentStatusIndex < #activeFunctions then
        currentStatusIndex = currentStatusIndex + 1
        StatusText.Text = activeFunctions[currentStatusIndex].name
        updateActiveFunctions()
    end
end)

