local navButtons = {}
local ICONS = { Home = "⌂", Main = "◆", ESP = "◎", Combat = "⚔" }
local ORDER = { "Home", "Main", "ESP", "Combat" }

local function selectSection(name)
    currentSection = name
    settingsOpen = false
    for secName, sec in pairs(sections) do sec.page.Visible = (secName == name) end
    for btnName, data in pairs(navButtons) do
        local active = (btnName == name)
        tw(data.btn, 0.2, { BackgroundTransparency = active and 0.78 or 1 })
        if active then
            data.line.Visible = true
            data.line.Size = UDim2.new(0, 0, 0, 4)
            data.line.Position = UDim2.new(0, 10, 1, -6)
            tw(data.line, 0.3, { Size = UDim2.new(0, 22, 0, 4) }, Enum.EasingStyle.Quart)
        else
            tw(data.line, 0.22, { Size = UDim2.new(0, 0, 0, 4), Position = UDim2.new(0, 6, 1, -6) })
            task.delay(0.24, function() if currentSection ~= btnName then data.line.Visible = false end end)
        end
    end
end

