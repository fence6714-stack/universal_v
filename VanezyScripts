local function stopESP()
    getgenv().ESPPlayers = false
    for _, conn in pairs(getgenv().ESPConnections) do
        pcall(function() conn:Disconnect() end)
    end
    getgenv().ESPConnections = {}
    for _, v in pairs(CoreGui:GetChildren()) do
        if v.Name == "ESP_Box" or v.Name == "ESP_Name" then v:Destroy() end
    end
end

local function updateESP()
    stopESP()
    if not getgenv().ESPPlayers then return end
    getgenv().ESPPlayers = true
    local function createESP(player)
        if player == Player then return end
        local box = Instance.new("Frame")
        box.Name = "ESP_Box"
        box.Size = UDim2.new(0, 0, 0, 0)
        box.BackgroundTransparency = 1
        box.BorderSizePixel = 2
        box.BorderColor3 = Color3.fromRGB(255, 80, 80)
        box.Parent = CoreGui
        
        local name = Instance.new("TextLabel")
        name.Name = "ESP_Name"
        name.Size = UDim2.new(0, 0, 0, 0)
        name.BackgroundTransparency = 1
        name.TextColor3 = Color3.fromRGB(255, 80, 80)
        name.Font = Enum.Font.GothamBold
        name.TextSize = 12
        name.Parent = CoreGui
        
        local conn = RunService.RenderStepped:Connect(function()
            if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
                box.Visible = false
                name.Visible = false
                return
            end
            local hrp = player.Character.HumanoidRootPart
            local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                box.Visible = true
                name.Visible = true
                local scale = 2000 / (pos.Z + 2000)
                local size = Vector2.new(40 * scale, 70 * scale)
                box.Size = UDim2.new(0, size.X, 0, size.Y)
                box.Position = UDim2.new(0, pos.X - size.X/2, 0, pos.Y - size.Y/2)
                name.Position = UDim2.new(0, pos.X - 30, 0, pos.Y - size.Y/2 - 20)
                name.Text = player.Name
            else
                box.Visible = false
                name.Visible = false
            end
        end)
        table.insert(getgenv().ESPConnections, conn)
    end
    for _, p in pairs(Players:GetPlayers()) do createESP(p) end
    local playerAdded = Players.PlayerAdded:Connect(function(p) createESP(p) end)
    local playerRemoving = Players.PlayerRemoving:Connect(function(p)
        for _, v in pairs(CoreGui:GetChildren()) do
            if (v.Name == "ESP_Box" or v.Name == "ESP_Name") and v:FindFirstChild("Player") and v.Player == p then
                v:Destroy()
            end
        end
    end)
    table.insert(getgenv().ESPConnections, playerAdded)
    table.insert(getgenv().ESPConnections, playerRemoving)
end

local function stopAimbot()
    getgenv().Aimbot = false
end

local function updateAimbot()
    if not getgenv().Aimbot then return end
    task.spawn(function()
        while getgenv().Aimbot do
            local closest = nil
            local closestDist = math.huge
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                    local pos, onScreen = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                    if onScreen then
                        local mousePos = UIS:GetMouseLocation()
                        local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                        if dist < closestDist and dist < 200 then
                            closestDist = dist
                            closest = p
                        end
                    end
                end
            end
            if closest and closest.Character and closest.Character:FindFirstChild("HumanoidRootPart") then
                local targetPos = Camera:WorldToViewportPoint(closest.Character.HumanoidRootPart.Position)
                local mousePos = UIS:GetMouseLocation()
                local delta = Vector2.new(targetPos.X, targetPos.Y) - mousePos
                mousemoverel(delta.X / 3, delta.Y / 3)
            end
            task.wait()
        end
    end)
end

