                    ColorSequenceKeypoint.new(0.5, Color3.fromHSV((tHue + 0.3) % 1, 0.5, 1)),
                    ColorSequenceKeypoint.new(1, Color3.fromHSV((tHue + 0.6) % 1, 0.5, 1)),
