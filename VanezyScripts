--==================================================================--
--  MAIN LOGIC LOOP  (imported functions, behavior unchanged)
--==================================================================--
conn(RunService.RenderStepped:Connect(function()
    Cam = workspace.CurrentCamera
    if not Cam then return end
    frame_count += 1

    update_esp()
    updateFly()

    if cfg.fov_changer then pcall(function() Cam.FieldOfView = cfg.fov_value end) end

    if cfg.world_color then
        local c = rgb(cfg.world_r, cfg.world_g, cfg.world_b)
        pcall(function() Lighting.Ambient = c; Lighting.OutdoorAmbient = c end)
    else
        pcall(function() Lighting.Ambient = orig_ambient; Lighting.OutdoorAmbient = orig_outdoor end)
    end

    if cfg.no_skybox and frame_count % 60 == 0 then
        pcall(function()
            for _, v in ipairs(Lighting:GetChildren()) do if v:IsA("Sky") then v:Destroy() end end
            Lighting.FogEnd = 999999; Lighting.Brightness = 0; Lighting.OutdoorAmbient = rgb(0, 0, 0)
        end)
    end

    local char = LP.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")

    if cfg.speedhack and hum then
        if hum.WalkSpeed ~= cfg.speed_val then hum.WalkSpeed = cfg.speed_val end
    elseif hum and not cfg.fly and hum.WalkSpeed ~= 16 then
        hum.WalkSpeed = 16
    end

    if cfg.noclip and char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end

    if cfg.fling then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LP and is_enemy(plr) then
                local c = plr.Character
                local r = c and c:FindFirstChild("HumanoidRootPart")
                if r then
                    r.Velocity = Vector3.new(math.random(-100,100), 50, math.random(-100,100))
                    r.RotVelocity = Vector3.new(math.random(-50,50), math.random(-50,50), math.random(-50,50))
                end
            end
        end
    end

    if cfg.no_recoil and hrp then
        pcall(function()
            for _, v in ipairs(hrp:GetChildren()) do
                if v:IsA("BodyVelocity") or v:IsA("BodyAngularVelocity") then
                    v.Velocity = Vector3.zero; v.AngularVelocity = Vector3.zero
                end
            end
        end)
    end

    if cfg.no_spread and char and frame_count % 10 == 0 then
        pcall(function()
            local tool = char:FindFirstChildOfClass("Tool")
            if tool then
                for _, v in ipairs(tool:GetDescendants()) do
                    if v:IsA("NumberValue") or v:IsA("IntValue") then
                        local n = v.Name:lower()
                        if n:find("spread") or n:find("recoil") or n:find("accuracy") then v.Value = 0 end
                    end
                end
            end
        end)
    end

    if cfg.aim then
        local target = find_target()
        if target and ray_visible(target) then
            local target_cf = CFrame.lookAt(Cam.CFrame.Position, target.Position)
            Cam.CFrame = Cam.CFrame:Lerp(target_cf, cfg.aim_smooth)
        end
    end
end))

