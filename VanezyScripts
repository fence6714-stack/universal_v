local function showGoodbyeAndClose()
    local _, yesBtn, noBtn, closeNotif = createNotification("Are you sure?", "Close VanezyHub?", 10, true)
    yesBtn.MouseButton1Click:Connect(function()
        closeNotif()
        SidePanel.Visible = false
        ContentPanel.Visible = false
        Header.Visible = false
        CollapseBtn.Visible = false
        local goodbyeText = Instance.new("TextLabel")
        goodbyeText.Size = UDim2.new(1, 0, 0, 50)
        goodbyeText.Position = UDim2.new(0, 0, 0.5, -25)
        goodbyeText.BackgroundTransparency = 1
        goodbyeText.Text = "See you soon..."
        goodbyeText.TextColor3 = Color3.fromRGB(255, 255, 255)
        goodbyeText.Font = Enum.Font.GothamBlack
        goodbyeText.TextSize = 24
        goodbyeText.TextTransparency = 1
        goodbyeText.Parent = MainFrame
        TweenService:Create(goodbyeText, TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 0}):Play()
        task.delay(2.5, function()
            TweenService:Create(goodbyeText, TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {TextTransparency = 1}):Play()
            TweenService:Create(MainFrame, TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1}):Play()
            TweenService:Create(ToggleBtn, TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1}):Play()
        end)
        task.delay(4, function()
            cleanupESP()
            disableAntiAFK()
            disableTriggerbot()
            disableFly()
            disableNoclip()
            if renderConnection then renderConnection:Disconnect() end
            pcall(function() MainGui:Destroy() end)
            pcall(function() NotifGui:Destroy() end)
            pcall(function() ToggleBtnGui:Destroy() end)
        end)
    end)
    noBtn.MouseButton1Click:Connect(function() closeNotif() end)
end

CloseBtn.MouseButton1Click:Connect(showGoodbyeAndClose)

