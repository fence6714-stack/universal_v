-- ===== RENDER LOOP =====
local renderConnection
renderConnection = RunService.RenderStepped:Connect(function()
    cache.frameSkip = cache.frameSkip + 1
    if cache.frameSkip % 2 == 0 then return end
    updateCache()

    local mid = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    fovCircle.Position = mid
    fovCircle.Radius = getgenv().FOVSize
    fovCircle.Visible = getgenv().Aimbot

    if getgenv().Aimbot then
        local target = findBestTarget()
        if target then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, target.Position), getgenv().AimSpeed)
        end
    end

    if getgenv().Fly and flyBodyVelocity then
        if getgenv().FlyMode == "PC" then
            local move = Vector3.new()
            if UIS:IsKeyDown(Enum.KeyCode.W) then move = move + Vector3.new(0, 0, -1) end
            if UIS:IsKeyDown(Enum.KeyCode.S) then move = move + Vector3.new(0, 0, 1) end
            if UIS:IsKeyDown(Enum.KeyCode.A) then move = move + Vector3.new(-1, 0, 0) end
            if UIS:IsKeyDown(Enum.KeyCode.D) then move = move + Vector3.new(1, 0, 0) end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0, 1, 0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then move = move + Vector3.new(0, -1, 0) end
            if move.Magnitude > 0 then
                flyBodyVelocity.Velocity = Camera.CFrame:VectorToWorldSpace(move.Unit * getgenv().FlySpeed)
            else
                flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
            end
            if flyGyro then
                flyGyro.CFrame = Camera.CFrame
            end
        else
            -- Mobile fly
            local screenH = Camera.ViewportSize.Y
            local screenW = Camera.ViewportSize.X
            local move = Vector3.new()
            if mobileTouchLeftActive then
                local centerX = screenW / 4
                local centerY = screenH / 2
                local dx = (mobileTouchLeft.X - centerX) / (screenW / 4)
                local dy = (mobileTouchLeft.Y - centerY) / (screenH / 2)
                dx = math.clamp(dx, -1, 1)
                dy = math.clamp(dy, -1, 1)
                move = Camera.CFrame:VectorToWorldSpace(Vector3.new(dx, 0, dy)) * getgenv().FlySpeed
            end
            if mobileTouchRightActive then
                local centerY = screenH / 2
                local dy = (mobileTouchRight - centerY) / (screenH / 2)
                dy = math.clamp(dy, -1, 1)
                move = move + Vector3.new(0, -dy * getgenv().FlySpeed, 0)
            end
            flyBodyVelocity.Velocity = move
            if flyGyro then
                flyGyro.CFrame = Camera.CFrame
            end
        end
    end

    if getgenv().SpeedBoost then
        local hum = getHum()
        if hum then hum.WalkSpeed = defaultWalkSpeed * getgenv().SpeedMultiplier end
    else
        local hum = getHum()
        if hum and hum.WalkSpeed ~= defaultWalkSpeed and not getgenv().Fly then
            hum.WalkSpeed = defaultWalkSpeed
        end
    end

    if getgenv().GodMode then
        local hum = getHum()
        if hum then
            if hum.MaxHealth < 99999 then hum.MaxHealth = 99999 end
            if hum.Health < hum.MaxHealth then hum.Health = hum.MaxHealth end
        end
    end
end)

