        local dots = 0
        while running do
            dots = dots % 3 + 1
            lbl.Text = "Loading" .. string.rep(".", dots)
            task.wait(0.35)
        end
    end)
    local spin
    spin = RunService.RenderStepped:Connect(function()
        if ov.Parent then rg.Rotation = (rg.Rotation + 6) % 360 else spin:Disconnect() end
    end)
    return function()
        running = false
        if spin then spin:Disconnect() end
        if ov then ov:Destroy() end
    end
end

local function changeColor(key)
    if frozen then return end
    frozen = true
    local newColor = PRESETS[key].c
    local snapshot = win:GetDescendants()
    local closeLoading = showLoading()
    -- 1) fade whole GUI slightly transparent
    tw(win, 0.5, { BackgroundTransparency = 0.5 })
    for _, d in ipairs(snapshot) do
        if d:IsA("TextLabel") or d:IsA("TextButton") then
            pcall(function() tw(d, 0.5, { TextTransparency = 0.6 }) end)
        elseif d:IsA("Frame") and d ~= wave then
            pcall(function() tw(d, 0.5, { BackgroundTransparency = math.clamp(d.BackgroundTransparency + 0.3, 0, 1) }) end)
        end
    end
    task.wait(0.5)
    -- 2) smooth 2.5s color transition
    local start = theme.primary
    local t0 = os.clock()
    while os.clock() - t0 < 2.5 do
        local a = (os.clock() - t0) / 2.5
        theme.primary = start:Lerp(newColor, a)
        applyTheme()
        RunService.RenderStepped:Wait()
    end
    theme.primary = newColor
    theme.key = key
    applyTheme()
    -- 3) fade back
    tw(win, 0.5, { BackgroundTransparency = 0.06 })
    for _, d in ipairs(snapshot) do
        if d:IsA("TextLabel") or d:IsA("TextButton") then pcall(function() tw(d, 0.5, { TextTransparency = 0 }) end) end
    end
    task.wait(0.5)
    closeLoading()
    frozen = false
    saveConfig()
    notify("Color saved", "loading of the preferred color is saved >" .. PRESETS[key].name .. " and white<", 4)
end

