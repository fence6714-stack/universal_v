-- ===== TRIGGERBOT =====
local function getEnemyAtCrosshair()
    local mPos = UIS:GetMouseLocation()
    local myHRP = getHRP()
    for _, p in pairs(Players:GetPlayers()) do
        if p == Player then continue end
        local char = p.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        if isTeammate(p) then continue end
        for _, partName in ipairs({"Head", "HumanoidRootPart"}) do
            local part = char:FindFirstChild(partName)
            if not part then continue end
            if myHRP and getgenv().ESPWallCheck and not hasLOS(myHRP.Position, part.Position) then continue end
            local vPos, onScreen = Camera:WorldToViewportPoint(part.Position)
            if not onScreen or vPos.Z <= 0 then continue end
            if (Vector2.new(vPos.X, vPos.Y) - mPos).Magnitude < 50 then return part end
        end
    end
    return nil
end

local function triggerFireTool(_, hitPart)
    local char = getChar()
    if not char then return end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return end
    local hitPos = hitPart and hitPart.Position or Mouse.Hit.Position
    for _, obj in ipairs(tool:GetDescendants()) do
        if not obj:IsA("RemoteEvent") then continue end
        pcall(function() obj:FireServer(hitPos, hitPart) end)
        pcall(function() obj:FireServer(hitPos) end)
    end
    for _, name in ipairs({"RE","Fire","Shoot","FireWeapon","ShootEvent","RemoteEvent"}) do
        local r = tool:FindFirstChild(name)
        if r and r:IsA("RemoteEvent") then
            pcall(function() r:FireServer(hitPos, hitPart) end)
            pcall(function() r:FireServer(hitPos) end)
        end
    end
end

local function enableTriggerbot()
    if triggerbotConn then return end
    triggerbotConn = RunService.Heartbeat:Connect(function()
        if not getgenv().Triggerbot then return end
        local hitPart = getEnemyAtCrosshair()
        if not hitPart then return end
        triggerFireTool(hitPart.Parent, hitPart)
    end)
end

local function disableTriggerbot()
    if triggerbotConn then triggerbotConn:Disconnect(); triggerbotConn = nil end
end

