        a.Font = Enum.Font.GothamBold
        a.TextSize = 20
        a.TextColor3 = color
        a.AutoButtonColor = false
        a.ZIndex = 47
        a.Parent = parent
        corner(a, 8)
        a.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
                flyDir[dirKey] = true; tw(a, 0.1, { BackgroundTransparency = 0 })
            end
        end)
        a.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
                flyDir[dirKey] = false; tw(a, 0.1, { BackgroundTransparency = 0.2 })
            end
        end)
    end
    local blue = rgb(90, 160, 255)
    arrow(leftPad, "︽", 46, 6,  blue, "f")
    arrow(leftPad, "︾", 46, 92, blue, "b")
    arrow(leftPad, "<", 6,  49, blue, "l")
    arrow(leftPad, ">", 86, 49, blue, "r")
