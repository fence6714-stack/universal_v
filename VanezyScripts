local flyPopupOpen = false

local function closeFlyPopup()
    if not flyPopupOpen then return end
    flyPopupOpen = false
    flyArrowBtn.Text = "v"
    TweenService:Create(flyModePopup, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 180, 0, 0)
    }):Play()
    task.delay(0.25, function() flyModePopup.Visible = false end)
end

local function openFlyPopup()
    if flyPopupOpen then closeFlyPopup(); return end
    flyPopupOpen = true
    flyArrowBtn.Text = "^"
    local pos = flyRowFrame.AbsolutePosition
    local sz = flyRowFrame.AbsoluteSize
    flyModePopup.Position = UDim2.new(0, pos.X + sz.X - 185, 0, pos.Y + sz.Y + 4)
    flyModePopup.Visible = true
    flyModePopup.Size = UDim2.new(0, 180, 0, 0)
    TweenService:Create(flyModePopup, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 180, 0, 74)
    }):Play()
end

