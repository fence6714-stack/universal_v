    track.MouseButton1Click:Connect(function()
        cfg[key] = not cfg[key]
        visual()
        if callback then callback(cfg[key]) end
    end)
    return f, lbl
end

-- SLIDER
local function makeSlider(parent, name, key, min, max, order, decimals)
    local f = makeRow(parent, order, 44)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -24, 0, 18)
    lbl.Position = UDim2.new(0, 12, 0, 4)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.GothamMedium
    lbl.TextSize = 13
    lbl.TextColor3 = rgb(210, 210, 220)
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.ZIndex = 4
    lbl.Parent = f
    local function fmt(v) return name .. ": " .. tostring(v) end
    lbl.Text = fmt(cfg[key])

    local track = Instance.new("Frame")
    track.Position = UDim2.new(0, 12, 0, 30)
    track.Size = UDim2.new(1, -24, 0, 5)
    track.BackgroundColor3 = rgb(50, 50, 58)
    track.BorderSizePixel = 0
    track.ZIndex = 4
    track.Parent = f
    corner(track, 3)
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(math.clamp((cfg[key]-min)/(max-min),0,1), 0, 1, 0)
    fill.BackgroundColor3 = WHITE
    fill.BorderSizePixel = 0
    fill.ZIndex = 5
    fill.Parent = track
    corner(fill, 3)
    local fillGrad = Instance.new("UIGradient")
    fillGrad.Parent = fill
    onTheme(function(p) fillGrad.Color = ColorSequence.new({ ColorSequenceKeypoint.new(0, p), ColorSequenceKeypoint.new(1, WHITE) }) end)
    local knob = Instance.new("TextButton")
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new(math.clamp((cfg[key]-min)/(max-min),0,1), 0, 0.5, 0)
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.BackgroundColor3 = WHITE
    knob.AutoButtonColor = false
    knob.Text = ""
    knob.ZIndex = 6
    knob.Parent = track
    corner(knob, 6)

    local dragging = false
    local function setFromX(mx)
        local pct = math.clamp((mx - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = min + pct * (max - min)
        if decimals and decimals > 0 then val = math.floor(val * 10^decimals) / 10^decimals else val = math.floor(val) end
        cfg[key] = val
        fill.Size = UDim2.new(pct, 0, 1, 0)
        knob.Position = UDim2.new(pct, 0, 0.5, 0)
        lbl.Text = fmt(val)
    end
    knob.MouseButton1Down:Connect(function() dragging = true end)
    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            dragging = true; setFromX(i.Position.X)
        end
    end)
    conn(UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end))
    conn(RunService.RenderStepped:Connect(function()
        if dragging then setFromX(UserInputService:GetMouseLocation().X) end
    end))
    return f, lbl
end

