-- ===== AIMBOT =====
local function getSilentAimTarget()
    local target, nearest = nil, getgenv().FOVSize
    local mid = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and p.Character then
            local hum = p.Character:FindFirstChild("Humanoid")
            local head = p.Character:FindFirstChild("Head")
            if hum and head and hum.Health > 0 then
                if isTeammate(p) then continue end
                local screen, visible = Camera:WorldToViewportPoint(head.Position)
                if visible then
                    local dist = (Vector2.new(screen.X, screen.Y) - mid).Magnitude
                    if dist < getgenv().FOVSize and dist < nearest then
                        nearest = dist
                        target = head
                    end
                end
            end
        end
    end
    return target
end

local function silentShoot()
    if not getgenv().Aimbot then return end
    local target = getSilentAimTarget()
    if not target then return end
    local tool = Player.Character and Player.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    local targetPos = target.Position + Vector3.new(0, 0.5, 0)
    for _, obj in ipairs(tool:GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            pcall(function() obj:FireServer(targetPos, target, Vector3.new(0, 1, 0)) end)
            pcall(function() obj:FireServer(targetPos, target) end)
            pcall(function() obj:FireServer(targetPos) end)
        end
    end
    for _, name in ipairs({"Fire", "Shoot", "RemoteEvent", "Hit", "Replicate"}) do
        local r = tool:FindFirstChild(name)
        if r and r:IsA("RemoteEvent") then
            pcall(function() r:FireServer(targetPos, target) end)
            pcall(function() r:FireServer(targetPos) end)
        end
    end
    pcall(function()
        local hitRemote = game:GetService("ReplicatedStorage"):FindFirstChild("Hit")
        if hitRemote then hitRemote:FireServer(targetPos, target) end
    end)
end

local function findBestTarget()
    local target, nearest = nil, getgenv().FOVSize
    local mid = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    if aimLockTarget and aimLockTarget.Parent then
        local humanoid = aimLockTarget.Parent:FindFirstChild("Humanoid")
        if humanoid and humanoid.Health > 0 then
            local screen, visible = Camera:WorldToViewportPoint(aimLockTarget.Position)
            if visible then
                local dist = (Vector2.new(screen.X, screen.Y) - mid).Magnitude
                if dist < getgenv().FOVSize * 1.5 then
                    return aimLockTarget
                end
            end
        end
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and p.Character then
            local humanoid = p.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                if not isTeammate(p) then
                    for _, partName in ipairs({"Head", "Torso", "HumanoidRootPart"}) do
                        local hitPart = p.Character:FindFirstChild(partName)
                        if hitPart then
                            local screen, visible = Camera:WorldToViewportPoint(hitPart.Position)
                            if visible then
                                local dist = (Vector2.new(screen.X, screen.Y) - mid).Magnitude
                                local score = dist
                                if partName == "Head" then score = score * 0.7 end
                                if dist < 100 then score = score * 0.5 end
                                if getgenv().ESPWallCheck then
                                    local myHRP = getHRP()
                                    if myHRP and not hasLOS(myHRP.Position, hitPart.Position) then continue end
                                end
                                if score < nearest then
                                    nearest = score
                                    target = hitPart
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    if target then aimLockTarget = target end
    return target
end

local function performShoot()
    local tool = Player.Character and Player.Character:FindFirstChildOfClass("Tool")
    if not tool then return end
    if tool:FindFirstChild("RemoteFunction") then
        pcall(function() tool.RemoteFunction:InvokeServer("Fire") end)
    end
    pcall(function() tool:Activate() end)
    if not UIS.TouchEnabled then
        pcall(function() if mouse1click then mouse1click() end end)
    end
end

local function autoShoot()
    if not getgenv().Aimbot or not getgenv().AutoShoot then return end
    local target = aimLockTarget
    if not target or not target.Parent then return end
    local hum = target.Parent:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return end
    local screenPos, onScreen = Camera:WorldToViewportPoint(target.Position)
    if not onScreen then return end
    local mid = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    if (Vector2.new(screenPos.X, screenPos.Y) - mid).Magnitude > getgenv().AutoShootFOV then return end
    local now = tick()
    if now - lastShootTime < getgenv().AutoShootDelay then return end
    lastShootTime = now
    performShoot()
end

task.spawn(function()
    while true do
        task.wait(0.05)
        pcall(autoShoot)
        if getgenv().Aimbot then pcall(silentShoot) end
    end
end)

-- ===== FLY PC =====
local function enableFlyPC()
    if flyBodyVelocity then return end
    local hrp = getHRP()
    if not hrp then return end
    flyGyro = Instance.new("BodyGyro")
    flyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    flyGyro.P = 1e4
    flyGyro.D = 1e3
    flyGyro.Parent = hrp
    flyBodyVelocity = Instance.new("BodyVelocity")
    flyBodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
    flyBodyVelocity.Parent = hrp
    local hum = getHum()
    if hum then
        hum.PlatformStand = true
    end
end

local function disableFlyPC()
    if flyBodyVelocity then
        flyBodyVelocity:Destroy()
        flyBodyVelocity = nil
    end
    if flyGyro then
        flyGyro:Destroy()
        flyGyro = nil
    end
    local hum = getHum()
    if hum then
        hum.PlatformStand = false
        hum.WalkSpeed = defaultWalkSpeed
    end
end

-- ===== FLY MOBILE =====
local mobileTouchLeft = Vector2.new(0, 0)
local mobileTouchRight = 0
local mobileTouchLeftActive = false
local mobileTouchRightActive = false

local function enableFlyMobile()
    if flyBodyVelocity then return end
    local hrp = getHRP()
    if not hrp then return end
    flyGyro = Instance.new("BodyGyro")
    flyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    flyGyro.P = 1e4
    flyGyro.D = 1e3
    flyGyro.Parent = hrp
    flyBodyVelocity = Instance.new("BodyVelocity")
    flyBodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
    flyBodyVelocity.Parent = hrp
    local hum = getHum()
    if hum then hum.PlatformStand = true end

    mobileFlyConn = UIS.TouchStarted:Connect(function(touch, _)
        local screenW = Camera.ViewportSize.X
        if touch.Position.X < screenW / 2 then
            mobileTouchLeftActive = true
            mobileTouchLeft = Vector2.new(touch.Position.X, touch.Position.Y)
        else
            mobileTouchRightActive = true
            mobileTouchRight = touch.Position.Y
        end
    end)
    UIS.TouchMoved:Connect(function(touch, _)
        local screenW = Camera.ViewportSize.X
        if touch.Position.X < screenW / 2 then
            mobileTouchLeft = Vector2.new(touch.Position.X, touch.Position.Y)
        else
            mobileTouchRight = touch.Position.Y
        end
    end)
    UIS.TouchEnded:Connect(function(touch, _)
        local screenW = Camera.ViewportSize.X
        if touch.Position.X < screenW / 2 then
            mobileTouchLeftActive = false
        else
            mobileTouchRightActive = false
        end
    end)
end

local function disableFlyMobile()
    disableFlyPC()
    if mobileFlyConn then mobileFlyConn:Disconnect(); mobileFlyConn = nil end
    mobileTouchLeftActive = false
    mobileTouchRightActive = false
end

local function enableFly()
    if getgenv().FlyMode == "Mobile" then
        enableFlyMobile()
    else
        enableFlyPC()
    end
end

local function disableFly()
    if getgenv().FlyMode == "Mobile" then
        disableFlyMobile()
    else
        disableFlyPC()
    end
end

