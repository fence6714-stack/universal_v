    corner(bar, 2)

    table.insert(activeNotifs, n)
    tw(f, 0.4, { Position = UDim2.new(1, 0, 0, 0) }, Enum.EasingStyle.Back)
    tw(bar, duration, { Size = UDim2.new(0, 0, 0, 3) }, Enum.EasingStyle.Linear)

    f.MouseButton1Click:Connect(function() dismissNotif(n) end)
    xb.MouseButton1Click:Connect(function() dismissNotif(n) end)
    local spin
    spin = RunService.RenderStepped:Connect(function()
        if f and f.Parent then sg.Rotation = (sg.Rotation + 1) % 360 else spin:Disconnect() end
    end)
    task.delay(duration, function() dismissNotif(n) end)
    return n
