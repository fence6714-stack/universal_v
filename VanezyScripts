local guiVisible = true
local savedPosition = nil

ToggleBtn.MouseButton1Click:Connect(function()
    if guiVisible then
        savedPosition = MainFrame.Position
        TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1}):Play()
        TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(0, GUI_WIDTH, 0, 0),
            Position = UDim2.new(0, 25, 0.5, 0)
        }):Play()
        task.delay(0.35, function() MainGui.Enabled = false end)
        TweenService:Create(ToggleBtn, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundColor3 = Color3.fromRGB(90, 90, 90)
        }):Play()
        guiVisible = false
    else
        MainGui.Enabled = true
        MainFrame.BackgroundTransparency = 1

        -- PART 4 FIX: restore state based on isMinimized
        if isMinimized then
            MainFrame.Size = UDim2.new(0, GUI_WIDTH, 0, 0)
            if savedPosition then
                MainFrame.Position = savedPosition
            else
                MainFrame.Position = UDim2.new(0, 25, 0.5, -24)
            end
            TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundTransparency = 0,
                Size = UDim2.new(0, GUI_WIDTH, 0, 48)
            }):Play()
            SidePanel.Visible = false
            ContentPanel.Visible = false
            CollapseBtn.Visible = false
            task.delay(0.1, function()
                StatusBar.Size = UDim2.new(0, 175, 0, 26)
                StatusBar.Position = UDim2.new(0.5, -87, 0.5, -13)
                StatusBar.BackgroundTransparency = 0
                MinLeftArrow.Visible = true
                MinRightArrow.Visible = true
                StatusToggleBg.Visible = true
                updateStatusBar()
            end)
        else
            MainFrame.Size = UDim2.new(0, GUI_WIDTH, 0, 0)
            if savedPosition then
                MainFrame.Position = savedPosition
            else
                MainFrame.Position = UDim2.new(0, 25, 0.5, -GUI_HEIGHT / 2)
            end
            TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundTransparency = 0,
                Size = UDim2.new(0, GUI_WIDTH, 0, GUI_HEIGHT)
            }):Play()
            SidePanel.Visible = true
            ContentPanel.Visible = true
            CollapseBtn.Visible = true
        end

        TweenService:Create(ToggleBtn, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundColor3 = Color3.fromRGB(255, 80, 80)
        }):Play()
        guiVisible = true
    end
end)

