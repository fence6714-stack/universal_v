-- reusable window drag (used by header + bottom grip); moves the whole window
local function makeWindowDrag(handle, onActive, onIdle)
    local dragging, startMouse, startX, startY = false, nil, 0, 0
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            if resizeActive then return end
            dragging = true
            startMouse = UserInputService:GetMouseLocation()
            startX, startY = winPosX, winPosY
            if onActive then onActive() end
        end
    end)
    conn(UserInputService.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            local d = UserInputService:GetMouseLocation() - startMouse
            winPosX = startX + d.X
            winPosY = startY + d.Y
            win.Position = UDim2.new(0.5, winPosX, 0.5, winPosY)
        end
    end))
    conn(UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            if dragging and onIdle then onIdle() end
            dragging = false
        end
    end))
end
