local activeNotifs = {}
local function dismissNotif(n)
    if n.dismissed then return end
    n.dismissed = true
    for i, v in ipairs(activeNotifs) do if v == n then table.remove(activeNotifs, i) break end end
    tw(n.frame, 0.35, { Position = UDim2.new(1, 320, 0, 0), BackgroundTransparency = 1 }, Enum.EasingStyle.Quart)
    task.delay(0.36, function() if n.frame then n.frame:Destroy() end end)
end

