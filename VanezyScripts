        corner(p, 14)
        local s = stroke(p, WHITE, 1.6, 1)
        local g = Instance.new("UIGradient"); g.Color = rainbowSequence(); g.Parent = s
        conn(RunService.RenderStepped:Connect(function() if p.Parent and p.Visible then g.Rotation = (g.Rotation + 1) % 360 end end))
        return p
    end
    leftPad = pad(0, 0)
    rightPad = pad(1, 1)

    local function arrow(parent, sym, px, py, color, dirKey)
        local a = Instance.new("TextButton")
