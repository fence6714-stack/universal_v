local function is_enemy(plr)
    if plr == LP then return false end
    if not LP.Team then return true end
    if not plr.Team then return true end
    return plr.Team ~= LP.Team
end

local function ray_visible(part)
    local char = LP.Character
    local origin = Cam.CFrame.Position
    local dir = part.Position - origin
    local dist = dir.Magnitude
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = char and { char } or {}
    local ray = workspace:Raycast(origin, dir.Unit * dist, params)
    if not ray then return true end
    return ray.Instance:IsDescendantOf(part.Parent)
end

local function find_target()
    local vs = Cam.ViewportSize
    local cx, cy = vs.X / 2, vs.Y / 2
    local best_dist, best_part = cfg.aim_fov, nil
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LP and is_enemy(plr) then
            local char = plr.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    local names = cfg.aim_hitbox == "Random" and { "Head", "HumanoidRootPart", "UpperTorso" } or { cfg.aim_hitbox }
                    for _, n in ipairs(names) do
                        local part = char:FindFirstChild(n) or char:FindFirstChild("HumanoidRootPart")
                        if part then
                            local sp, vis = Cam:WorldToViewportPoint(part.Position)
                            if vis and sp.Z > 0 then
                                local d = (Vector2.new(cx, cy) - Vector2.new(sp.X, sp.Y)).Magnitude
                                if d < best_dist then best_dist = d; best_part = part end
                            end
                        end
                    end
                end
            end
        end
    end
    return best_part
end

-- Drawing-based ESP
local function make_line() local l = Drawing and Drawing.new("Line"); if l then l.Visible=false; l.Thickness=1; l.From=Vector2.zero; l.To=Vector2.zero end return l end
local function make_box() local t = {}; for _=1,4 do t[#t+1]=make_line() end return t end
local function make_text()
    local t = Drawing and Drawing.new("Text")
    if t then t.Visible=false; t.Size=13; t.Color=WHITE; t.Outline=true; t.OutlineColor=rgb(0,0,0); t.Font=2; t.Center=true end
    return t
end
local function ensure_esp(plr)
    if not esp_objects[plr] then
        esp_objects[plr] = { box=make_box(), health=make_line(), name=make_text(), dist=make_text(), tracer=make_line() }
    end
    return esp_objects[plr]
end
local function remove_esp(plr)
    local e = esp_objects[plr]; if not e then return end
    for _, o in pairs(e) do
        if type(o) == "table" then for _, v in pairs(o) do if v and v.Remove then pcall(function() v:Remove() end) end end
        elseif o and o.Remove then pcall(function() o:Remove() end) end
    end
    esp_objects[plr] = nil
end
local function clear_esp() for plr in pairs(esp_objects) do remove_esp(plr) end end
local function hide_esp(e)
    for i=1,4 do if e.box[i] then e.box[i].Visible=false end end
    if e.health then e.health.Visible=false end
    if e.name then e.name.Visible=false end
    if e.dist then e.dist.Visible=false end
    if e.tracer then e.tracer.Visible=false end
end
local function update_esp()
    if not cfg.esp then clear_esp(); return end
    if not Drawing then return end
    local vs = Cam.ViewportSize
    local col = esp_color()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LP then
            local e = ensure_esp(plr)
            local char = plr.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if root and hum and hum.Health > 0 then
                local pos, vis = Cam:WorldToViewportPoint(root.Position)
                if vis and pos.Z > 0 then
                    local top_sp = Cam:WorldToViewportPoint(root.Position + Vector3.new(0,3,0))
                    local bot_sp = Cam:WorldToViewportPoint(root.Position - Vector3.new(0,3,0))
                    local top = Vector2.new(top_sp.X, top_sp.Y)
                    local bot = Vector2.new(bot_sp.X, bot_sp.Y)
                    local h = math.abs(top.Y - bot.Y)
                    local w = h * 0.6
                    if cfg.esp_box then
                        local cr = {
                            Vector2.new(top.X-w/2, top.Y), Vector2.new(top.X+w/2, top.Y),
                            Vector2.new(top.X+w/2, bot.Y), Vector2.new(top.X-w/2, bot.Y),
                        }
                        for i=1,4 do local l=e.box[i]; if l then l.From=cr[i]; l.To=cr[i%4+1]; l.Color=col; l.Visible=true end end
                    else for i=1,4 do if e.box[i] then e.box[i].Visible=false end end end
                    if cfg.esp_health and e.health then
                        local pct = math.clamp(hum.Health/hum.MaxHealth, 0, 1)
                        e.health.From = Vector2.new(top.X-w/2-4, bot.Y)
                        e.health.To   = Vector2.new(top.X-w/2-4, bot.Y-h*pct)
                        e.health.Color = rgb(255-255*pct, 255*pct, 0)
                        e.health.Visible = true
                    elseif e.health then e.health.Visible=false end
                    if cfg.esp_name and e.name then
                        e.name.Text=plr.Name; e.name.Position=Vector2.new(top.X, top.Y-16); e.name.Color=col; e.name.Visible=true
                    elseif e.name then e.name.Visible=false end
                    if cfg.esp_dist and e.dist then
                        local mr = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                        if mr then
                            e.dist.Text = math.floor((mr.Position-root.Position).Magnitude).."m"
                            e.dist.Position = Vector2.new(top.X, bot.Y+2); e.dist.Color=rgb(180,180,180); e.dist.Visible=true
                        end
                    elseif e.dist then e.dist.Visible=false end
                    if cfg.esp_tracers and e.tracer then
                        e.tracer.From=Vector2.new(vs.X/2, vs.Y); e.tracer.To=Vector2.new(pos.X,pos.Y); e.tracer.Color=col; e.tracer.Visible=true
                    elseif e.tracer then e.tracer.Visible=false end
                else hide_esp(e) end
            else hide_esp(e) end
        end
    end
end

