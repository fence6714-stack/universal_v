local function getActiveFuncs()
    local list = {}
    if getgenv().ESPPlayers then table.insert(list, {name = "ESP", key = "ESPPlayers"}) end
    if getgenv().ESPTeammates then table.insert(list, {name = "ESP Team", key = "ESPTeammates"}) end
    if getgenv().Aimbot then table.insert(list, {name = "Aim", key = "Aimbot"}) end
    if getgenv().Tracers then table.insert(list, {name = "Trace", key = "Tracers"}) end
    if getgenv().AntiAFK then table.insert(list, {name = "AFK", key = "AntiAFK"}) end
    if getgenv().AutoShoot then table.insert(list, {name = "Shoot", key = "AutoShoot"}) end
    if getgenv().Fly then table.insert(list, {name = "Fly", key = "Fly"}) end
    if getgenv().Noclip then table.insert(list, {name = "Noclip", key = "Noclip"}) end
    if getgenv().SpeedBoost then table.insert(list, {name = "Speed", key = "SpeedBoost"}) end
    if getgenv().InfiniteJump then table.insert(list, {name = "Jump", key = "InfiniteJump"}) end
    if getgenv().Triggerbot then table.insert(list, {name = "Trigger", key = "Triggerbot"}) end
    if getgenv().ESPWallCheck then table.insert(list, {name = "WallCheck", key = "ESPWallCheck"}) end
    if getgenv().GodMode then table.insert(list, {name = "God", key = "GodMode"}) end
    if getgenv().FullBright then table.insert(list, {name = "Bright", key = "FullBright"}) end
    return list
end

local function updateStatusBar()
    local activeFuncs = getActiveFuncs()
    if #activeFuncs == 0 then
        StatusText.Text = "No active"
        leftArrow.Visible = false
        rightArrow.Visible = false
        MinLeftArrow.Visible = false
        MinRightArrow.Visible = false
        StatusToggleBg.Visible = false
        return
    end
    local currentIndex = tonumber(StatusBar:GetAttribute("CurrentIndex")) or 1
    if currentIndex > #activeFuncs then currentIndex = 1 end
    if currentIndex < 1 then currentIndex = 1 end
    StatusText.Text = activeFuncs[currentIndex].name
    StatusBar:SetAttribute("CurrentIndex", currentIndex)
    StatusBar:SetAttribute("CurrentKey", activeFuncs[currentIndex].key)

    if isMinimized then
        leftArrow.Visible = false
        rightArrow.Visible = false
        MinLeftArrow.Visible = true
        MinRightArrow.Visible = true
        if #activeFuncs <= 1 then
            MinLeftArrow.TextColor3 = Color3.fromRGB(80, 80, 80)
            MinRightArrow.TextColor3 = Color3.fromRGB(80, 80, 80)
        else
            MinLeftArrow.TextColor3 = (currentIndex > 1) and Color3.fromRGB(200, 200, 200) or Color3.fromRGB(80, 80, 80)
            MinRightArrow.TextColor3 = (currentIndex < #activeFuncs) and Color3.fromRGB(200, 200, 200) or Color3.fromRGB(80, 80, 80)
        end
        local key = activeFuncs[currentIndex].key
        StatusToggleBg.Visible = true
        if getgenv()[key] then
            StatusToggleBg.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
            StatusToggleDot:TweenPosition(UDim2.new(1, -16, 0.5, -7), "Out", "Quad", 0.2, true)
        else
            StatusToggleBg.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            StatusToggleDot:TweenPosition(UDim2.new(0, 2, 0.5, -7), "Out", "Quad", 0.2, true)
        end
    else
        MinLeftArrow.Visible = false
        MinRightArrow.Visible = false
        StatusToggleBg.Visible = false
        leftArrow.Visible = false
        rightArrow.Visible = false
    end
end

local function stepStatus(dir)
    local activeFuncs = getActiveFuncs()
    if #activeFuncs <= 1 then return end
    local idx = (StatusBar:GetAttribute("CurrentIndex") or 1) + dir
    if idx < 1 then idx = #activeFuncs end
    if idx > #activeFuncs then idx = 1 end
    StatusBar:SetAttribute("CurrentIndex", idx)
    TweenService:Create(StatusText, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, dir > 0 and -4 or 20, 0, 0)
    }):Play()
    task.wait(0.1)
    updateStatusBar()
    TweenService:Create(StatusText, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 8, 0, 0)
    }):Play()
end

leftArrow.MouseButton1Click:Connect(function() stepStatus(-1) end)
rightArrow.MouseButton1Click:Connect(function() stepStatus(1) end)
MinLeftArrow.MouseButton1Click:Connect(function() if isMinimized then stepStatus(-1) end end)
MinRightArrow.MouseButton1Click:Connect(function() if isMinimized then stepStatus(1) end end)

