local popupHue = 0
task.spawn(function()
    while true do
        if not flyModePopup.Visible or not flyModePopup.Parent then task.wait(0.5); continue end
        popupHue = (popupHue + 0.005) % 1
        pcall(function()
            popupGradient.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromHSV(popupHue, 0.5, 1)),
                ColorSequenceKeypoint.new(0.5, Color3.fromHSV((popupHue + 0.3) % 1, 0.5, 1)),
                ColorSequenceKeypoint.new(1, Color3.fromHSV((popupHue + 0.6) % 1, 0.5, 1)),
            })
        end)
        task.wait(0.03)
    end
end)
