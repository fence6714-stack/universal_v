pcall(function()
    if isfile and isfile("VanezyHub_settings.txt") then
        local data = readfile("VanezyHub_settings.txt")
        for line in data:gmatch("[^\n]+") do
            local k, v = line:match("^(.-)=(.+)$")
            if k and v then
                local num = tonumber(v)
                if num then getgenv()[k] = num end
            end
        end
    end
end)

